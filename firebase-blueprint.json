{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A project containing prompt engineering data and images",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Project ID" },
        "ownerUid": { "type": "string", "description": "UID of the owner" },
        "name": { "type": "string", "description": "Project name" },
        "parts": { "type": "object", "description": "Prompt parts (mainObject, style, etc.)" },
        "improvedPrompt": { "type": "string", "description": "The AI-improved prompt" },
        "finalPrompt": { "type": "string", "description": "The final prompt sent to image generation" },
        "architectureJson": { "type": "string", "description": "Architectural JSON data" },
        "annotations": { "type": "array", "items": { "type": "object" }, "description": "Floor plan annotations" },
        "uploadedImages": { "type": "array", "items": { "type": "string" }, "description": "Base64 encoded images" },
        "referenceImage": { "type": "string", "description": "Base64 encoded reference image" },
        "generatedImageUrl": { "type": "string", "description": "URL or base64 of generated image" },
        "history": { "type": "array", "items": { "type": "object" }, "description": "Prompt history" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["ownerUid", "name"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project documents containing all app state"
    }
  }
}
